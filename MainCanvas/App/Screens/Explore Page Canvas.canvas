{
	"nodes":[
		{"id":"22d06932f4c780b9","type":"group","x":1040,"y":80,"width":1275,"height":1127,"label":"Large Hero Cards"},
		{"id":"8bb8b49108cbd003","type":"group","x":1220,"y":-500,"width":1051,"height":440,"label":"Untitled group"},
		{"id":"646d68f717c7d7f6","type":"file","file":"zManagment/Media/Pasted image 20260622123832.png","x":-371,"y":360,"width":177,"height":400},
