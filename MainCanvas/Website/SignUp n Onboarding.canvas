		{"id":"4d0146571efefd47","type":"group","x":1720,"y":-3620,"width":2080,"height":700,"color":"3","label":"Type 3"},
		{"id":"7b5af69a659a05f0","type":"group","x":-1800,"y":-3930,"width":960,"height":620,"color":"1","label":"ANIMATED"},
