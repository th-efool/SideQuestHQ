		{"id":"b5a4b66ddc877ff7","type":"file","file":"zManagment/Media/Pasted image 20260621143500.png","x":-4746,"y":-3789,"width":887,"height":549},
		{"id":"a562fcf197ce72f0","type":"file","file":"zManagment/Media/Pasted image 20260621144309.png","x":-5780,"y":-3790,"width":844,"height":580},
		{"id":"f240f94886363322","type":"file","file":"zManagment/Media/Pasted image 20260621121906.png","x":420,"y":-4820,"width":828,"height":516},
