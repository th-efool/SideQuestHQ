{
	"nodes":[
		{"id":"57d39e5248bd6711","type":"group","x":-5860,"y":-3900,"width":2994,"height":2105,"label":"Type 4"},
		{"id":"52fe9a9fdb0d8a42","type":"group","x":1480,"y":-2731,"width":3600,"height":1680,"label":"Type5 - Misc"},
		{"id":"ef387ca60c998182","type":"group","x":-1900,"y":-4020,"width":2120,"height":2577,"color":"2"},
