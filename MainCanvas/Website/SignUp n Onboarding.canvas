			"toSide":"left"
		},
		{
			"id":"0bc8dce939bcf5c6",
			"styleAttributes":{},
			"toFloating":false,
			"fromNode":"f79e09e0077a9331",
			"fromSide":"bottom",
			"toNode":"b8160c9fbd5b6a58",
			"toSide":"bottom"
